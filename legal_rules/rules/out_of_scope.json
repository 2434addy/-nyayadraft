{
  "doc_type": "out_of_scope",
  "min_chars": 250,
  "max_chars": 1100,
  "require_disclaimer": false,
  "is_document": false,
  "required_patterns": [
    { "id": "scope_statement", "description": "States drafting-only scope / no legal advice", "regex": "(?i)(legal\\s+advice|only\\s+(draft|work\\s+with|able\\s+to\\s+draft)|draft(ing)?\\s+(documents?|assistant)|document\\s+types|outside\\s+(the\\s+)?scope|can(not|'t)\\s+(advise|predict|represent))", "legal_basis": "CONFIDENT" },
    { "id": "advocate_recommendation", "description": "Recommends consulting a qualified advocate/lawyer", "regex": "(?i)(advocate|lawyer|legal\\s+practitioner)", "legal_basis": "CONFIDENT" }
  ],
  "forbidden_patterns": [
    { "id": "no_outcome_prediction", "description": "No win/lose predictions", "regex": "(?i)you\\s+(will|would)\\s+(likely\\s+|probably\\s+)?(win|lose|succeed)" },
    { "id": "no_advice_directive", "description": "No 'you should sue/file' advice (but not when declining: 'whether you should sue')", "regex": "(?i)(?<!whether )(?<!if )you\\s+should\\s+(sue|file\\s+a\\s+(case|complaint|suit)|go\\s+to\\s+court)" },
    { "id": "no_document_body", "description": "No numbered operative clauses (refusal must not contain a draft)", "regex": "(?m)^\\s*\\d+\\.\\s.+\\n\\s*\\d+\\.\\s" },
    { "id": "no_md_heading", "description": "No markdown headings", "regex": "(?m)^\\s{0,3}#{1,6}\\s" },
    { "id": "no_md_bold", "description": "No markdown bold", "regex": "\\*\\*" },
    { "id": "no_ai_voice", "description": "No AI self-reference", "regex": "(?i)as an ai\\b" },
    { "id": "no_chat_preamble", "description": "No chatty preamble", "regex": "(?i)\\A\\s*(sure|certainly|here(\\s+is|'s))\\b" }
  ]
}
