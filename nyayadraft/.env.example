# Base URL of the NyayaDraft Express backend (deployed on Render).
# Copy this file to `.env.local` and set it to your backend's URL.
#
# RunPod credentials (RUNPOD_API_URL / RUNPOD_API_KEY) live in backend/.env,
# not here — the frontend only talks to the backend, never to RunPod directly.

# No trailing slash. Locally, point this at the backend dev server
# (http://localhost:3001).
NEXT_PUBLIC_API_URL=your_render_url_here
