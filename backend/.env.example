# RunPod serverless endpoint that hosts the fine-tuned NyayaDraft model.
# Copy this file to `.env` and fill in your real values.

# The /run endpoint of your RunPod serverless deployment.
RUNPOD_API_URL=https://api.runpod.ai/v2/your_endpoint_id/run

# Your RunPod API key (sent as: Authorization: Bearer <key>).
RUNPOD_API_KEY=your_runpod_api_key

# Port the server listens on. Render injects PORT automatically; locally
# this defaults to 3001 when unset.
PORT=3001

# Comma-separated list of allowed CORS origins (your deployed frontend URL).
# Leave unset to reflect the request origin (convenient for local dev).
FRONTEND_ORIGIN=https://your-app.vercel.app

# Supabase project credentials, used to verify the caller's JWT so only
# authenticated users can generate documents. Use the same project as the
# frontend (NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
